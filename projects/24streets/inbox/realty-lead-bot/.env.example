# Скопируйте этот файл в .env и заполните своими значениями.

# Токен бота от @BotFather (обязательно)
TELEGRAM_TOKEN=

# ID группы риэлторов для уведомлений (узнать через @getidsbot), например: -1001234567890
TELEGRAM_GROUP_ID=

# Путь к локальной базе (по умолчанию leads.db рядом с ботом)
# DB_PATH=leads.db

# Путь к базе объектов krisha-parser для автоматического матчинга лидов
# По умолчанию ищет ../krisha-parser/listings.db
# LISTINGS_DB_PATH=../krisha-parser/listings.db

# --- Google Sheets (опционально) ---
USE_GOOGLE_SHEETS=false
GOOGLE_SHEET_NAME=Лидогенератор
GOOGLE_CREDENTIALS_FILE=credentials.json
